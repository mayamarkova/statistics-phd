<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Шпаргалка · SPSS Навигатор</title>
  <link rel="stylesheet" href="styles.css">
  <style>
.shpargalka-shell * {box-sizing: border-box;
    margin: 0;
    padding: 0;}
.shpargalka-shell {font-family: Arial, "DejaVu Sans", sans-serif;
    font-size: 7pt;
    color: #1a1a1a;
    line-height: 1.2;
    padding: 3mm;}
.shpargalka-shell .header {text-align: center;
    padding: 2px 0 4px 0;
    border-bottom: 2px solid #2c3e50;
    margin-bottom: 5px;}
.shpargalka-shell .header h1 {font-size: 12pt;
    color: #2c3e50;
    font-weight: bold;
    margin: 0;}
.shpargalka-shell .header .subtitle {font-size: 7.5pt;
    color: #555;
    margin-top: 1px;}
.shpargalka-shell /* Оформление в 3 колони чрез таблица - най-съвместимо */
.layout {width: 100%;
    border-collapse: separate;
    border-spacing: 4px 0;}
.shpargalka-shell .layout > tbody > tr > td {width: 33.33%;
    vertical-align: top;
    padding: 0;}
.shpargalka-shell .section {border: 1px solid #bbb;
    border-radius: 3px;
    padding: 3px 5px;
    background: #fafafa;
    margin-bottom: 4px;}
.shpargalka-shell .section-title {font-size: 8pt;
    font-weight: bold;
    padding: 2px 5px;
    margin: -3px -5px 3px -5px;
    border-radius: 2px 2px 0 0;
    color: white;}
.shpargalka-shell .compare {background: #1565c0;}
.shpargalka-shell .correlate {background: #00695c;}
.shpargalka-shell .regression {background: #c62828;}
.shpargalka-shell .categorical {background: #6a1b9a;}
.shpargalka-shell .assumptions {background: #ef6c00;}
.shpargalka-shell .descriptives {background: #37474f;}
.shpargalka-shell .report {background: #5d4037;}
.shpargalka-shell .tbl {width: 100%;
    border-collapse: collapse;
    font-size: 6.5pt;}
.shpargalka-shell .tbl th {background: #e8e8e8;
    padding: 2px 3px;
    text-align: left;
    font-weight: bold;
    border-bottom: 1px solid #999;
    font-size: 6.5pt;}
.shpargalka-shell .tbl td {padding: 2px 3px;
    border-bottom: 1px solid #e0e0e0;
    vertical-align: top;}
.shpargalka-shell .tbl tr:last-child td {border-bottom: none;}
.shpargalka-shell .test-name {font-weight: bold;
    color: #1565c0;
    white-space: nowrap;}
.shpargalka-shell .correlate-name {color: #00695c; font-weight: bold;}
.shpargalka-shell .regression-name {color: #c62828; font-weight: bold;}
.shpargalka-shell .categorical-name {color: #6a1b9a; font-weight: bold;}
.shpargalka-shell .nonparam {color: #c62828; font-weight: bold;}
.shpargalka-shell .spss-path {font-family: "Courier New", monospace;
    font-size: 6pt;
    background: #f0f0f0;
    padding: 1px 3px;
    border-radius: 2px;
    color: #333;}
.shpargalka-shell .use-case {font-style: italic;
    color: #555;
    font-size: 6.3pt;
    line-height: 1.25;}
.shpargalka-shell .small-note {font-size: 5.8pt;
    color: #777;}
.shpargalka-shell .check-list {list-style: none;
    padding: 0;
    margin: 0;}
.shpargalka-shell .check-list li {padding: 1.5px 0 1.5px 12px;
    position: relative;
    font-size: 6.5pt;
    line-height: 1.3;}
.shpargalka-shell .check-list li:before {content: "✓";
    position: absolute;
    left: 0;
    color: #00695c;
    font-weight: bold;}
.shpargalka-shell .check-list li.warn:before {content: "⚠";
    color: #ef6c00;}
.shpargalka-shell .footer {margin-top: 5px;
    padding: 4px 8px;
    background: #fff3e0;
    border: 1px solid #ef6c00;
    border-radius: 3px;
    font-size: 7pt;
    color: #444;
    text-align: center;
    line-height: 1.35;}
.shpargalka-shell .footer strong {color: #c62828;}
.shpargalka-shell .p-interp {display: table;
    width: 100%;
    margin-top: 2px;
    border-spacing: 3px 0;}
.shpargalka-shell .p-box {display: table-cell;
    padding: 3px 4px;
    border-radius: 3px;
    text-align: center;
    font-size: 6.5pt;}
.shpargalka-shell .p-sig {background: #c8e6c9; color: #1b5e20;}
.shpargalka-shell .p-nosig {background: #ffcdd2; color: #b71c1c;}
.shpargalka-shell .mini-note {font-size: 6pt;
    color: #666;
    font-style: italic;
    margin-top: 3px;
    padding-top: 3px;
    border-top: 1px dotted #ccc;
    line-height: 1.3;}
.shpargalka-shell .legend-row {margin-top: 3px;
    font-size: 6pt;}
.shpargalka-shell .legend-item {display: inline-block;
    padding: 1px 5px;
    border-radius: 2px;
    margin-right: 4px;}
.shpargalka-shell .legend-blue {background: #e3f2fd; color: #0d47a1;}
.shpargalka-shell .legend-red {background: #ffebee; color: #b71c1c;}
.shpargalka-shell .apa-label {font-weight: bold;
    color: #5d4037;
    font-size: 7pt;
    margin-top: 4px;
    margin-bottom: 2px;}
.shpargalka-shell .print-hint {text-align: center;
    background: #e3f2fd;
    padding: 5px;
    margin-bottom: 8px;
    border-radius: 3px;
    font-size: 8pt;
    color: #0d47a1;}
.shpargalka-shell {padding: 0;}
</style>
</head>
<body data-page="shpargalka">
